{
  "name": "iflow-desktop",
  "private": true,
  "version": "1.8.1",
  "type": "module",
  "description": "iFlow Desktop - AI 编程助手桌面应用",
  "author": "XY-JX",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run --config vite.config.test.ts",
    "test:watch": "vitest --config vite.config.test.ts",
    "package": "powershell -ExecutionPolicy Bypass -File ./package-build.ps1",
    "task:add": "node scripts/task-manager.js add",
    "task:list": "node scripts/task-manager.js list",
    "task:complete": "node scripts/task-manager.js complete",
    "task:delete": "node scripts/task-manager.js delete",
    "task:move": "node scripts/task-manager.js move",
    "task:stats": "node scripts/task-manager.js stats"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.1.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^13.0.0",
    "prettier": "^3.8.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue-tsc": "^2.0.0"
  }
}
