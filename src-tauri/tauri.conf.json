{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "height": 900,
        "label": "main",
        "minHeight": 600,
        "minWidth": 1000,
        "resizable": true,
        "title": "我的一个梦 - Desktop",
        "width": 1400
      }
    ],
    "withGlobalTauri": false
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installerHooks": "nsis-installer.nsh"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "identifier": "com.iflow.desktop",
  "plugins": {},
  "productName": "我的一个梦",
  "version": "1.8.1"
}