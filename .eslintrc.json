{
  "rules": {
    // TypeScript 规则
    "@typescript-eslint/no-unused-vars": "warn",
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/strict-boolean-expressions": "off",
    
    // Vue 规则
    "vue/multi-word-component-names": "off",
    "vue/no-mutating-props": "warn",
    "vue/require-default-prop": "off",
    
    // ESLint 规则
    "no-console": "warn",
    "no-debugger": "warn",
    "prefer-const": "warn",
    "no-var": "error"
  },
  "globals": {
    "describe": "readonly",
    "it": "readonly",
    "expect": "readonly",
    "beforeEach": "readonly",
    "afterEach": "readonly",
    "beforeAll": "readonly",
    "afterAll": "readonly"
  }
}
